; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Idle Dot Shooter"
run/main_scene="uid://ddnbhknq4k5yy"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/app/icon.svg"

[autoload]

AudioManager="*res://systems/audio/AudioManager.gd"
UpgradeManager="*res://systems/progression/UpgradeManager.gd"
SaveManager="*res://systems/progression/SaveManager.gd"
CardDatabase="*res://systems/progression/CardDatabase.gd"
RunManager="*res://systems/progression/RunManager.gd"
TelemetryOverlay="*res://ui/overlays/telemetry_overlay.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"
DebugMenu="*uid://cggqb75a8w8r"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/borderless=true
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg", "res://addons/godot_ai/plugin.cfg")

[rendering]

anti_aliasing/quality/msaa_2d=3
anti_aliasing/quality/msaa_3d=3
anti_aliasing/quality/screen_space_aa=2
anti_aliasing/quality/use_taa=true
